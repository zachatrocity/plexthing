# PlexThing Local Development Settings
# Copy this file to .env and fill in your values
# These values will be used as fallbacks when DeskThing settings are not configured

# Plex Server URL (e.g., http://192.168.1.100:32400 or https://plex.yourdomain.com)
PLEX_SERVER_URL=http://localhost:32400

# Your Plex authentication token
# Get it from Plex Web → Settings → Account → Plex Token
# Or from: https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
PLEX_TOKEN=

# Target player client identifier (optional)
# Leave empty for auto-discovery
PLAYER_IDENTIFIER=
